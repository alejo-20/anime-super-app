{
  "expo": {
    "name": "AnimeApp",
    "slug": "anime-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tuapp.animeapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.tuapp.animeapp"
    },
    "web": {
      "favicon": "assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1d0c3638-a2e0-4867-9ddf-ff8cfa597e92"
      }
    }
  }
}